FLASK_APP=app.py
FLASK_SECRET_KEY=zmien-mnie-na-dluzszy-losowy-ciag

# Dane z Azure Portal -> App registrations -> (Twoja aplikacja)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Tenant ANS Elblag (mozna wpisac domene np. ans-elblag.pl albo GUID tenanta)
# lub 'common' dla dowolnego konta Microsoft
MS_TENANT_ID=common

# URL na ktory Azure przekieruje po logowaniu (musi byc zarejestrowany w Azure)
MS_REDIRECT_URI=http://localhost:5000/auth/callback

# Baza danych (Postgres w Dockerze - patrz docker-compose.yml w katalogu nadrzednym)
POSTGRES_DB=praktyki_db
POSTGRES_USER=praktyki
POSTGRES_PASSWORD=haslo
DATABASE_URL=postgresql+psycopg2://praktyki:haslo@localhost:5433/praktyki_db

# Dev-only: 1 wlacza szybkie logowanie na dowolnego usera z bazy (bez MS)
DEV_LOGIN=0
